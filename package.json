{
  "name": "litvm-testnet-bot",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "start": "node tools/menu.mjs",
    "menu": "node tools/menu.mjs",
    "bot": "tsx src/main.ts",
    "bot:dry": "tsx src/main.ts --dry-run",
    "bot:live": "tsx src/main.ts --no-dry-run",
    "schedule": "tsx src/main.ts --schedule",
    "daemon": "tsx src/main.ts --daemon",
    "check": "tsx src/main.ts --check --no-dashboard",
    "gen": "tsx src/main.ts --gen",
    "discover": "tsx tools/discover.ts",
    "verify": "tsx tools/verify-deployment.ts",
    "faucet": "node tools/faucet-claim.mjs",
    "faucet:loop": "node tools/faucet-claim.mjs --loop",
    "faucet:3h": "node tools/faucet-claim.mjs --loop --hours 3",
    "capture": "node tools/capture-browser.mjs"
  },
  "dependencies": {
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.61.1",
    "socks-proxy-agent": "^10.0.0",
    "undici": "^8.4.0",
    "viem": "^2.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
